{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true
  },
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true
  },
  "javascript.preferences.autoImportFileExcludePatterns": ["lucide-react"],
  "js/ts.preferences.autoImportFileExcludePatterns": ["lucide-react"],
  "oxc.configPath": "./frontend/.oxlintrc.json",
  "oxc.path.tsgolint": "./frontend/node_modules/.bin/tsgolint",
  "search.exclude": {
    "**/routeTree.gen.ts": true
  },
  "typescript.preferences.autoImportFileExcludePatterns": ["lucide-react"],
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  }
}
